<?xml version='1.0' encoding='utf-8'?>
<SettingsFile xmlns="uri:settings" CurrentProfile="(Default)">
  <Profiles>
    <Profile Name="(Default)" />
  </Profiles>
  <Settings>
    <Setting Name="BundleID" Type="System.String" Scope="User">
      <Value Profile="(Default)">com.company.placeHolderBundleID</Value>
    </Setting>
    <Setting Name="Port" Type="System.String" Scope="User">
      <Value Profile="(Default)">55000</Value>
    </Setting>
  </Settings>
</SettingsFile>